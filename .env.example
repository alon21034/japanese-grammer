LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# Optional: if you only push to one specific user.
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: local testing mode.
# - When enabled, webhook signature check is skipped.
# - LINE push/reply calls are not sent to LINE API, but logged to data/line_mock_events.jsonl.
# - Lesson and grammar detail are generated fully offline.
LOCAL_TEST_MODE=0
LOCAL_TEST_USER_ID=Ulocaltest

# Optional: server startup defaults for scripts/run_webhook.py
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8000
WEBHOOK_RELOAD=1

# Optional: secure cron trigger endpoint (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=change_me

# Optional: read synced datasets from Vercel Blob when local files are missing.
# Example:
# BLOB_PUBLIC_BASE_URL=https://<your-store-id>.public.blob.vercel-storage.com
# BLOB_DATA_PREFIX=prod
BLOB_PUBLIC_BASE_URL=
BLOB_DATA_PREFIX=

# Optional: change data/state location if needed.
# On Vercel, if DATA_DIR is not set, default becomes /tmp/japanese-grammer-data
DATA_DIR=./data
